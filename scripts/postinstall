#!/usr/bin/env bash
set -euo pipefail

APP_NAME="latch"
PLIST_LABEL="com.local.$APP_NAME"
APP_DST="/Applications/$APP_NAME.app"
BINARY="$APP_DST/Contents/MacOS/$APP_NAME"
LOG_FILE="Library/Logs/$APP_NAME.log"
PLIST_TEMPLATE="$APP_DST/Contents/Resources/$PLIST_LABEL.plist"

# Detect the console user (the person sitting at the Mac, not root)
CONSOLE_USER=$(stat -f "%Su" /dev/console)
if [[ -z "$CONSOLE_USER" || "$CONSOLE_USER" == "root" ]]; then
    echo "Could not determine console user; skipping LaunchAgent install."
    exit 0
fi

USER_HOME=$(dscl . -read "/Users/$CONSOLE_USER" NFSHomeDirectory | awk '{print $2}')
USER_UID=$(id -u "$CONSOLE_USER")
AGENTS_DIR="$USER_HOME/Library/LaunchAgents"
PLIST_DST="$AGENTS_DIR/$PLIST_LABEL.plist"

mkdir -p "$AGENTS_DIR"

# Substitute placeholders in the bundled plist template
sed \
    -e "s|BINARY_PATH_PLACEHOLDER|$BINARY|g" \
    -e "s|LOG_PATH_PLACEHOLDER|$USER_HOME/$LOG_FILE|g" \
    "$PLIST_TEMPLATE" > "$PLIST_DST"

chown "$CONSOLE_USER" "$PLIST_DST"
chmod 644 "$PLIST_DST"

# Ad-hoc sign the bundle — required for UNUserNotificationCenter on macOS 13+.
# Without at least an ad-hoc signature, requestAuthorization returns UNError Code=1.
codesign --sign - --force --deep "$APP_DST"

# Reset Input Monitoring (ListenEvent) TCC permission for this bundle ID.
# Ad-hoc signing produces a new hash on every build, so macOS silently revokes
# the permission after an upgrade — leaving a stale entry with no re-prompt.
# Resetting here forces macOS to prompt again on next launch, giving the user
# a clean Allow dialog instead of a broken/silent failure.
tccutil reset ListenEvent "com.local.$APP_NAME" 2>/dev/null || true

# Register the app bundle with LaunchServices so macOS recognises it as
# notification-capable (required for UNUserNotificationCenter to grant permission
# when launched as a LaunchAgent directly by launchd).
LSREGISTER="/System/Library/Frameworks/CoreServices.framework/Frameworks/LaunchServices.framework/Support/lsregister"
"$LSREGISTER" -f "$APP_DST"

# Stop any running instance before reloading — without this the old binary stays
# in memory while the new one is installed, leaving two processes running.
# bootout unregisters the agent; pkill terminates the live process.
sudo -u "$CONSOLE_USER" launchctl bootout "gui/$USER_UID/$PLIST_LABEL" 2>/dev/null || true
pkill -x "$APP_NAME" 2>/dev/null || true
sleep 1

# Re-register and start the updated version
sudo -u "$CONSOLE_USER" launchctl bootstrap "gui/$USER_UID" "$PLIST_DST"

echo ""
echo "latch installed."
echo "IMPORTANT: Grant Input Monitoring permission for the keyboard switcher:"
echo "  System Settings > Privacy & Security > Input Monitoring"
echo "  Add: $BINARY"
